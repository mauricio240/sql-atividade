create table copa_do_mundo (
id serial primary key not null,
selecao text,
valor_de_mercado int,
ranking_fifa int,
artilheiro text,
grupo_da_copa varchar (1)
);
--Chave Primaria: Identificador único de uma tabela. Essa informação não pode se repetir em nenhum momento--
--Chave estrangeira: A chave que é referenciada em outra tabela--
--Varchar: é um limitador da quantidade de caracteres. Dentro do parenteses é o valor que define o limite--
